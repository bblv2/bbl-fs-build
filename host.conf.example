# bbl-fs-build per-host configuration. This file is read TWICE:
#   - On the operator's local machine, by scripts/provision.sh, which
#     embeds it into the Linode user_data so the new box receives it.
#   - On the new box, by setup.sh, to render templates and configure
#     services.
#
# Copy this to /etc/bbl-fs-host.conf on the operator side, fill in
# secrets, then point provision.sh at it via --host-conf=/path/to/host.conf
#
# NEVER commit a filled-in copy to git — it contains secrets.

# ── REQUIRED — bbl-fs-config knobs ───────────────────────────────────

# The box's public IPv4. Must match the Linode you're provisioning.
BBL_EXTERNAL_IP=

# The box's FQDN. Must resolve to BBL_EXTERNAL_IP (set DNS first or
# use a Floating IP that can be reassigned).
BBL_DOMAIN=

# ── REQUIRED — secrets ───────────────────────────────────────────────

# SignalWire FreeSWITCH apt repo token. Obtain from
# https://signalwire.com/ → Personal Access Token. Free tier is fine.
BBL_SIGNALWIRE_TOKEN=

# Backblaze B2 credentials for nightly recording archive.
# Generate per-bucket scoped keys at https://secure.backblaze.com/app_keys.htm
# Required perms: listFiles, readFiles, writeFiles on bucket bbl-fs-recordings
BBL_B2_KEY_ID=
BBL_B2_APP_KEY=

# ── OPTIONAL — defaults sufficient for typical BBL infra ─────────────

BBL_HEP_TARGET=172.105.152.19:9060
BBL_ESL_OUTBOUND_IP=50.116.36.14
BBL_ESL_OUTBOUND=50.116.36.14:8085
BBL_REC_PATH=/opt/fs-qc-recordings
BBL_CERT_EMAIL=admin@brandedbridgeline.com

# Optional override of where bbl-fs-config lives (e.g., for testing
# a config branch before merging to main):
# BBL_CONFIG_REPO=git@github.com:bblv2/bbl-fs-config.git
# BBL_CONFIG_BRANCH=main
